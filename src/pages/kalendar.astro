---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const kalendarEntries = await getCollection('kalendar');
const sveVijesti = await getCollection('vijesti');
const vijestiKaoDogadaji = sveVijesti.filter(v => {
  if (!v.data.date_start) return false;
  return v.data.je_dogadaj !== false;
});

interface RawEvent {
  id: string;
  link: string;
  data: {
    title: string;
    date_start: string | Date;
    date_end?: string | Date;
    location: string;
    discipline: string;
    level?: string;
    propozicije?: string;
  };
}

const sviRaw: RawEvent[] = [
  ...kalendarEntries.map(e => ({ id: e.id, link: `/kalendar/${e.id.replace(/\.md$/, '')}`, data: e.data as RawEvent['data'] })),
  ...vijestiKaoDogadaji.map(e => ({ id: e.id, link: `/${e.id.replace(/\.md$/, '')}`, data: e.data as RawEvent['data'] })),
];

const _now = Date.now();

function endTime(e: RawEvent): number {
  return e.data.date_end ? new Date(e.data.date_end).getTime() : new Date(e.data.date_start).getTime();
}

const upcomingRaw = sviRaw
  .filter(e => endTime(e) >= _now)
  .sort((a, b) => new Date(a.data.date_start).getTime() - new Date(b.data.date_start).getTime());

const pastRaw = sviRaw
  .filter(e => endTime(e) < _now)
  .sort((a, b) => new Date(b.data.date_start).getTime() - new Date(a.data.date_start).getTime());

const monthNames = ['Siječanj','Veljača','Ožujak','Travanj','Svibanj','Lipanj','Srpanj','Kolovoz','Rujan','Listopad','Studeni','Prosinac'];

const disciplineLabels: Record<string, string> = {
  preponsko: 'Preponsko jahanje',
  dresurno: 'Dresurno jahanje',
  daljinsko: 'Daljinsko jahanje',
  vise: 'Više disciplina'
};
const levelLabels: Record<string, string> = {
  medunarodno: 'Međunarodno',
  drzavno: 'Državno',
  regionalno: 'Regionalno'
};

function formatDate(date: Date): string {
  return `${date.getDate()}.${date.getMonth()+1}.${date.getFullYear()}.`;
}
function formatDateRange(start: Date, end?: Date): string {
  if (!end) return formatDate(start);
  if (start.getMonth() === end.getMonth() && start.getFullYear() === end.getFullYear()) {
    return `${start.getDate()}.–${end.getDate()}.${end.getMonth()+1}.${end.getFullYear()}.`;
  }
  return `${formatDate(start)} – ${formatDate(end)}`;
}

interface ProcessedEvent {
  link: string;
  title: string;
  day: number;
  monthShort: string;
  discipline: string;
  disciplineLabel: string;
  level: string | undefined;
  levelLabel: string;
  dateRange: string;
  location: string;
  propozicije?: string;
  isOngoing: boolean;
}

interface MonthGroup {
  label: string;
  events: ProcessedEvent[];
}

function processEvents(raw: RawEvent[]): ProcessedEvent[] {
  return raw.map(ev => {
    const start = new Date(ev.data.date_start);
    const end = ev.data.date_end ? new Date(ev.data.date_end) : undefined;
    const startTime = start.getTime();
    const et = end ? end.getTime() : startTime;
    const isOngoing = startTime <= _now && et >= _now;
    return {
      link: ev.link,
      title: ev.data.title,
      day: start.getDate(),
      monthShort: monthNames[start.getMonth()].substring(0, 3),
      discipline: ev.data.discipline,
      disciplineLabel: disciplineLabels[ev.data.discipline] || ev.data.discipline,
      level: ev.data.level,
      levelLabel: ev.data.level ? (levelLabels[ev.data.level] || '') : '',
      dateRange: formatDateRange(start, end),
      location: ev.data.location,
      propozicije: ev.data.propozicije,
      isOngoing,
    };
  });
}

function groupByMonth(raw: RawEvent[], processed: ProcessedEvent[]): MonthGroup[] {
  const groups: MonthGroup[] = [];
  const seen = new Set<string>();
  for (let i = 0; i < raw.length; i++) {
    const d = new Date(raw[i].data.date_start);
    const key = `${d.getFullYear()}-${d.getMonth()}`;
    if (!seen.has(key)) {
      seen.add(key);
      groups.push({
        label: `${monthNames[d.getMonth()]} ${d.getFullYear()}.`,
        events: processed.filter((_, idx) => {
          const ed = new Date(raw[idx].data.date_start);
          return `${ed.getFullYear()}-${ed.getMonth()}` === key;
        }),
      });
    }
  }
  return groups;
}

const upcomingProcessed = processEvents(upcomingRaw);
const pastProcessed = processEvents(pastRaw);
const upcomingGroups = groupByMonth(upcomingRaw, upcomingProcessed);
const pastGroups = groupByMonth(pastRaw, pastProcessed);
---
<BaseLayout title="Kalendar natjecanja" activePage="/kalendar">

  <section class="page-hero">
    <div class="page-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">Kalendar</span>
      </div>
      <h1>Kalendar natjecanja</h1>
      <p>Pregled svih nadolazećih natjecanja i turnira u organizaciji ili pod pokroviteljstvom Zagrebačkog konjičkog saveza.</p>
    </div>
  </section>

  <section class="section kalendar-section">
    <div class="kalendar-inner">

      <!-- NADOLAZEĆA -->
      <div class="kal-section-header reveal">
        <h2 class="kal-section-title">
          <span class="kal-section-dot upcoming-dot"></span>
          Nadolazeća natjecanja
        </h2>
        <span class="kal-section-count">{upcomingProcessed.length} {upcomingProcessed.length === 1 ? 'natjecanje' : upcomingProcessed.length > 1 && upcomingProcessed.length < 5 ? 'natjecanja' : 'natjecanja'}</span>
      </div>

      {upcomingProcessed.length === 0 && (
        <div class="kalendar-empty reveal">
          <p>Trenutno nema zakazanih natjecanja. Provjerite ponovno uskoro.</p>
        </div>
      )}

      {upcomingGroups.map((group) => (
        <div class="kalendar-month reveal">
          <div class="kalendar-month-header">
            <h3>{group.label}</h3>
            <span class="kalendar-month-count">{group.events.length} {group.events.length === 1 ? 'natjecanje' : 'natjecanja'}</span>
          </div>
          <div class="kalendar-events">
            {group.events.map((ev) => (
              <a href={ev.link} class={`kalendar-card${ev.isOngoing ? ' ongoing' : ''}`}>
                <div class="kalendar-card-date">
                  <span class="kalendar-card-day">{ev.day}</span>
                  <span class="kalendar-card-month">{ev.monthShort}</span>
                </div>
                <div class="kalendar-card-body">
                  <div class="kalendar-card-tags">
                    <span class={`kalendar-tag disc-${ev.discipline}`}>{ev.disciplineLabel}</span>
                    {ev.level && <span class="kalendar-tag level">{ev.levelLabel}</span>}
                    {ev.isOngoing && <span class="kalendar-tag ongoing-tag">U tijeku</span>}
                    {ev.propozicije && <span class="kalendar-tag pdf-tag">Propozicije PDF</span>}
                  </div>
                  <h4>{ev.title}</h4>
                  <div class="kalendar-card-info">
                    <span class="kalendar-card-info-item">
                      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      {ev.dateRange}
                    </span>
                    <span class="kalendar-card-info-item">
                      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {ev.location}
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <!-- PROŠLA -->
      {pastProcessed.length > 0 && (
        <div class="past-section reveal">
          <div class="kal-section-header">
            <h2 class="kal-section-title">
              <span class="kal-section-dot past-dot"></span>
              Prošla natjecanja
            </h2>
            <span class="kal-section-count">{pastProcessed.length} {pastProcessed.length === 1 ? 'natjecanje' : 'natjecanja'}</span>
          </div>

          {pastGroups.map((group) => (
            <div class="kalendar-month">
              <div class="kalendar-month-header">
                <h3>{group.label}</h3>
                <span class="kalendar-month-count">{group.events.length} {group.events.length === 1 ? 'natjecanje' : 'natjecanja'}</span>
              </div>
              <div class="kalendar-events">
                {group.events.map((ev) => (
                  <a href={ev.link} class="kalendar-card past">
                    <div class="kalendar-card-date past-date">
                      <span class="kalendar-card-day">{ev.day}</span>
                      <span class="kalendar-card-month">{ev.monthShort}</span>
                    </div>
                    <div class="kalendar-card-body">
                      <div class="kalendar-card-tags">
                        <span class={`kalendar-tag disc-${ev.discipline}`}>{ev.disciplineLabel}</span>
                        {ev.level && <span class="kalendar-tag level">{ev.levelLabel}</span>}
                        <span class="kalendar-tag past-tag">Završeno</span>
                        {ev.propozicije && <span class="kalendar-tag pdf-tag">Propozicije PDF</span>}
                      </div>
                      <h4>{ev.title}</h4>
                      <div class="kalendar-card-info">
                        <span class="kalendar-card-info-item">
                          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                          {ev.dateRange}
                        </span>
                        <span class="kalendar-card-info-item">
                          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                          {ev.location}
                        </span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

    </div>
  </section>

</BaseLayout>

<style>
  .kalendar-section { background: var(--off-white); }
  .kalendar-inner { max-width: 900px; margin: 0 auto; }
  .kalendar-empty { text-align: center; padding: 3rem 2rem; color: var(--gray-500); font-size: 1rem; }

  /* Section headers */
  .kal-section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 2rem;
  }
  .kal-section-title {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--serif); font-size: 1.6rem; font-weight: 700; color: var(--gray-800);
  }
  .kal-section-dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  }
  .upcoming-dot { background: var(--blue); }
  .past-dot { background: var(--gray-400); }
  .kal-section-count { font-size: 0.82rem; color: var(--gray-400); font-weight: 500; }

  /* Past section separator */
  .past-section { margin-top: 4rem; padding-top: 3rem; border-top: 2px dashed var(--gray-200); }

  /* Month groups */
  .kalendar-month { margin-bottom: 2.5rem; }
  .kalendar-month-header {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-bottom: 0.6rem; margin-bottom: 1rem;
    border-bottom: 1px solid var(--gray-200);
  }
  .kalendar-month-header h3 {
    font-family: var(--serif); font-size: 1.05rem; font-weight: 700; color: var(--gray-600);
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .kalendar-month-count { font-size: 0.75rem; color: var(--gray-400); font-weight: 500; }

  /* Cards */
  .kalendar-events { display: flex; flex-direction: column; gap: 0.75rem; }

  .kalendar-card {
    display: flex; gap: 1.2rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px; padding: 1.25rem 1.5rem;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    text-decoration: none; color: inherit;
  }
  .kalendar-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    border-color: var(--blue-nav);
  }
  .kalendar-card.ongoing { border-left: 4px solid var(--blue); }
  .kalendar-card.past { opacity: 0.6; }
  .kalendar-card.past:hover { opacity: 1; }

  /* Date badge */
  .kalendar-card-date {
    flex-shrink: 0; width: 52px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: var(--blue-pale); border-radius: 6px; padding: 0.5rem 0.4rem;
  }
  .past-date { background: var(--gray-100); }
  .kalendar-card-day {
    font-family: var(--serif); font-size: 1.5rem; font-weight: 700; color: var(--blue); line-height: 1;
  }
  .past-date .kalendar-card-day { color: var(--gray-500); }
  .kalendar-card-month {
    font-size: 0.62rem; font-weight: 700; color: var(--blue);
    text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0.15rem;
  }
  .past-date .kalendar-card-month { color: var(--gray-400); }

  /* Card body */
  .kalendar-card-body { flex: 1; min-width: 0; }
  .kalendar-card-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.45rem; }
  .kalendar-tag {
    font-size: 0.6rem; font-weight: 700; padding: 0.2rem 0.5rem;
    border-radius: 2px; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .disc-preponsko { background: #e8f5e9; color: #2e7d32; }
  .disc-dresurno  { background: #e3f2fd; color: #1565c0; }
  .disc-daljinsko { background: #fff3e0; color: #e65100; }
  .disc-vise      { background: var(--blue-pale); color: var(--blue); }
  .kalendar-tag.level      { background: var(--gray-100); color: var(--gray-600); }
  .kalendar-tag.ongoing-tag { background: #c8e6c9; color: #1b5e20; }
  .kalendar-tag.past-tag   { background: var(--gray-100); color: var(--gray-400); }
  .kalendar-tag.pdf-tag    { background: #fff3e0; color: #bf360c; }

  .kalendar-card h4 {
    font-family: var(--serif); font-size: 1rem; font-weight: 700;
    color: var(--gray-800); line-height: 1.35; margin-bottom: 0.45rem;
  }

  .kalendar-card-info { display: flex; flex-wrap: wrap; gap: 1rem; }
  .kalendar-card-info-item {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.8rem; color: var(--gray-500); font-weight: 500;
  }
  .kalendar-card-info-item svg { width: 13px; height: 13px; flex-shrink: 0; }

  @media (max-width: 640px) {
    .kal-section-title { font-size: 1.3rem; }
    .kalendar-card { flex-direction: column; gap: 0.75rem; padding: 1rem; }
    .kalendar-card-date { width: auto; flex-direction: row; gap: 0.4rem; padding: 0.35rem 0.75rem; align-self: flex-start; }
    .kalendar-card-info { flex-direction: column; gap: 0.35rem; }
  }
</style>
