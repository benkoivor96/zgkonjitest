---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="O nama" activePage="/o-nama">

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">O nama</span>
      </div>
      <h1>O nama</h1>
      <p>Zagrebački konjički savez — krovna institucija u razvoju konjičkog sporta u Gradu Zagrebu s više od sedam desetljeća tradicije.</p>
    </div>
  </section>

  <!-- ABOUT INTRO -->
  <section class="section about-intro" id="o-savezu">
    <div class="about-intro-inner">
      <div class="about-intro-img reveal">
        <img src="https://images.unsplash.com/photo-1553284965-83fd3e82fa5a?w=900&q=80" alt="Hipodrom Zagreb">
      </div>
      <div class="about-intro-text reveal">
        <div class="section-label">O savezu</div>
        <h2 class="section-title">Više od sedam desetljeća konjičkog sporta</h2>
        <p>Zagrebački konjički savez krovna je institucija u razvoju konjičkog sporta u Gradu Zagrebu. Savez broji 11 aktivnih klubova s preko 400 aktivnih jahača — natjecatelja, rekreativaca, polaznika škola jahanja i terapeutskih programa.</p>
        <div class="about-highlight">
          Naši natjecatelji nastupaju na raznim međunarodnim natjecanjima kao predstavnici Zagrebačkog konjičkog saveza i tijekom godina ostvarili smo značajne rezultate na državnoj i međunarodnoj konjičkoj sceni.
        </div>
        <p>Savez organizira natjecanja u tri FEI discipline — preponskom jahanju, dresurnom jahanju i daljinskom jahanju — te provodi Prvenstvo Grada Zagreba, Zagrebačku konjičku ligu i tradicionalni Lipanjski turnir koji se održava od 1955. godine.</p>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- LEADERSHIP -->
  <section class="section leadership" id="vodstvo">
    <div class="leadership-inner">
      <div class="leadership-header reveal">
        <div class="section-label">Vodstvo</div>
        <h2 class="section-title">Upravljačka tijela saveza</h2>
        <p class="section-desc">Vodstvo Zagrebačkog konjičkog saveza predano radi na razvoju konjičkog sporta, organizaciji natjecanja i podršci klubovima.</p>
      </div>

      <div class="leadership-top">
        <div class="leader-card reveal">
          <div class="leader-avatar">DD</div>
          <h3>Damir Djelmić</h3>
          <div class="leader-role">Predsjednik</div>
        </div>
        <div class="leader-card reveal reveal-d1">
          <div class="leader-avatar">DG</div>
          <h3>Denis Gugić</h3>
          <div class="leader-role">Dopredsjednik</div>
        </div>
        <div class="leader-card reveal reveal-d2">
          <div class="leader-avatar">TK</div>
          <h3>Tomo Kadić</h3>
          <div class="leader-role">Glavni tajnik</div>
        </div>
      </div>

      <div class="board-section">
        <div class="board-group reveal">
          <div class="board-group-title">Izvršni odbor</div>
          <div class="board-members">
            <span class="board-member chair"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Damir Djelmić — predsjednik</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Denis Gugić</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Andrea Novak Djelmić</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Janja Žic</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Iva Jurak Lukičić</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Renato Levanić</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Ante Šimleša</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Kristijan Babić</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Zdravko Balaško</span>
          </div>
        </div>
        <div class="board-group reveal">
          <div class="board-group-title">Nadzorni odbor</div>
          <div class="board-members">
            <span class="board-member chair"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Pane Handžinski — predsjednik</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Petar Jurčević</span>
            <span class="board-member"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>Marko Ulaga</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="kontakt">
    <div class="contact-inner">
      <div class="reveal">
        <div class="section-label">Kontakt</div>
        <h2 class="section-title">Kontaktni podaci</h2>
        <p class="section-desc">Imate pitanja o natjecanjima, članstvu ili školi jahanja? Javite nam se.</p>
        <div class="contact-cards">
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
            <div>
              <div class="contact-card-label">Adresa</div>
              <div class="contact-card-value">Trg Krešimira Ćosića 11</div>
              <div class="contact-card-value small">10 000 Zagreb, Hrvatska</div>
            </div>
          </div>
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></div>
            <div>
              <div class="contact-card-label">Telefon</div>
              <div class="contact-card-value">092 30 60 943</div>
            </div>
          </div>
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
            <div>
              <div class="contact-card-label">E-mail</div>
              <div class="contact-card-value">zgkonji@gmail.com</div>
            </div>
          </div>
        </div>
      </div>
      <div class="contact-map reveal reveal-d1">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2781.3!2d15.9745!3d45.8125!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4765d70b9b3a5555%3A0x1234567890abcdef!2sTrg%20Kre%C5%A1imira%20%C4%86osi%C4%87a%2011%2C%2010000%2C%20Zagreb!5e0!3m2!1shr!2shr!4v1700000000000!5m2!1shr!2shr" loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <!-- BANK INFO -->
  <section class="bank-info">
    <div class="bank-inner reveal">
      <div class="bank-item">
        <div class="bank-label">OIB</div>
        <div class="bank-value">56195699333</div>
      </div>
      <div class="bank-item">
        <div class="bank-label">Banka</div>
        <div class="bank-value">Erste&amp;Steiermärkische Bank d.d.</div>
      </div>
      <div class="bank-item">
        <div class="bank-label">IBAN</div>
        <div class="bank-value">HR32 2402 0061 1000 4900 1</div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .about-intro { background: var(--white); }
  .about-intro-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-intro-img { border-radius: 8px; overflow: hidden; aspect-ratio: 4/3; }
  .about-intro-img img { width: 100%; height: 100%; object-fit: cover; }
  .about-intro-text p { font-size: 0.95rem; color: var(--gray-600); line-height: 1.8; margin-bottom: 1rem; }
  .about-highlight { background: var(--blue-pale); border-left: 3px solid var(--blue); padding: 1rem 1.2rem; border-radius: 0 6px 6px 0; margin: 1.2rem 0; font-size: 0.92rem; color: var(--blue-dark); line-height: 1.7; font-weight: 500; }

  .leadership { background: var(--off-white); }
  .leadership-inner { max-width: 1200px; margin: 0 auto; }
  .leadership-header { text-align: center; margin-bottom: 3rem; }
  .leadership-header .section-desc { margin: 0 auto; }
  .leadership-top { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2.5rem; }
  .leader-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: 8px; padding: 2rem 1.5rem; text-align: center; transition: transform 0.3s, box-shadow 0.3s; }
  .leader-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.06); }
  .leader-avatar { width: 64px; height: 64px; background: var(--blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-family: var(--serif); font-size: 1.2rem; font-weight: 700; color: #fff; }
  .leader-card h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.3rem; }
  .leader-role { font-size: 0.78rem; color: var(--blue); font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }

  .board-section { margin-top: 1rem; }
  .board-group { background: var(--white); border: 1px solid var(--gray-200); border-radius: 8px; padding: 1.8rem 2rem; margin-bottom: 1.5rem; }
  .board-group-title { font-family: var(--serif); font-size: 1rem; font-weight: 700; color: var(--blue); margin-bottom: 1rem; }
  .board-members { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .board-member { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--blue-pale); padding: 0.4rem 0.85rem; border-radius: 4px; font-size: 0.85rem; font-weight: 500; color: var(--gray-700); }
  .board-member svg { width: 14px; height: 14px; color: var(--blue); flex-shrink: 0; }
  .board-member.chair { font-weight: 700; color: var(--blue); }

  .contact-section { background: var(--white); }
  .contact-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; }
  .contact-cards { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 1.5rem; }
  .contact-card { display: flex; gap: 1rem; align-items: flex-start; background: var(--off-white); border: 1px solid var(--gray-200); border-radius: 8px; padding: 1.2rem; transition: border-color 0.3s; }
  .contact-card:hover { border-color: var(--blue-nav); }
  .contact-icon { width: 42px; height: 42px; flex-shrink: 0; background: var(--blue); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .contact-icon svg { width: 18px; height: 18px; color: #fff; }
  .contact-card-label { font-size: 0.65rem; color: var(--gray-400); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; margin-bottom: 0.15rem; }
  .contact-card-value { font-size: 0.95rem; color: var(--gray-800); font-weight: 600; }
  .contact-card-value.small { font-size: 0.85rem; font-weight: 500; color: var(--gray-600); }
  .contact-map { border-radius: 8px; overflow: hidden; border: 1px solid var(--gray-200); min-height: 420px; }
  .contact-map iframe { width: 100%; height: 100%; min-height: 420px; border: 0; }

  .bank-info { background: var(--blue); padding: 3rem 2rem; }
  .bank-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .bank-item { text-align: center; }
  .bank-label { font-size: 0.65rem; color: rgba(255,255,255,0.5); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; margin-bottom: 0.35rem; }
  .bank-value { font-size: 1rem; color: #fff; font-weight: 600; word-break: break-all; }

  @media (max-width: 1024px) {
    .about-intro-inner { grid-template-columns: 1fr; gap: 2rem; }
    .leadership-top { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; margin-bottom: 2.5rem; }
    .contact-inner { grid-template-columns: 1fr; }
    .bank-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  @media (max-width: 640px) {
    .board-group { padding: 1.2rem; }
  }
</style>
