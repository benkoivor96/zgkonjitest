---
/*
  index.astro — NASLOVNICA
  Vijesti se automatski učitavaju iz src/content/vijesti/
  Kad klijent doda vijest u CMS → pojavi se ovdje.
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Dohvati sve vijesti, sortiraj po datumu (najnovije prvo), uzmi 3
const sveVijesti = await getCollection('vijesti');
const vijesti = sveVijesti
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Helper za formatiranje datuma na hrvatski
function formatDate(date: Date): string {
  const months = ['siječnja','veljače','ožujka','travnja','svibnja','lipnja','srpnja','kolovoza','rujna','listopada','studenoga','prosinca'];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}.`;
}

// Helper za label kategorije
function categoryLabel(cat?: string): string {
  const labels: Record<string, string> = { najave: 'Najave', vijesti: 'Vijesti', rezultati: 'Rezultati' };
  return labels[cat || ''] || '';
}

function disciplineLabel(disc?: string): string {
  const labels: Record<string, string> = { preponsko: 'Preponsko', dresurno: 'Dresura', daljinsko: 'Daljinsko' };
  return labels[disc || ''] || '';
}
---
<BaseLayout title="Naslovnica">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        70. Lipanjski turnir · FEI World Cup · 11.–14. lipnja 2026.
      </div>
      <h1>Tradicija konjičkog sporta u srcu Zagreba</h1>
      <p>Više od sedam desetljeća razvijamo preponsko, dresurno i daljinsko jahanje te organiziramo natjecanja na najvišoj razini — od Hipodroma do svjetske scene.</p>
      <div class="hero-actions">
        <a href="/lipanjski-turnir" class="btn btn-primary">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          FEI World Cup 2026
        </a>
        <a href="/konjicki-sport" class="btn btn-outline">
          Istraži discipline
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="stats-bar-inner">
      <div class="stat-item reveal"><div class="stat-number">70+</div><div class="stat-label">Godina tradicije</div></div>
      <div class="stat-item reveal reveal-d1"><div class="stat-number">3</div><div class="stat-label">FEI discipline</div></div>
      <div class="stat-item reveal reveal-d2"><div class="stat-number">9+</div><div class="stat-label">Klubova članova</div></div>
      <div class="stat-item reveal reveal-d3"><div class="stat-number">1.</div><div class="stat-label">FEI World Cup u HR</div></div>
    </div>
  </div>

  <!-- VIJESTI -->
  <section class="section vijesti" id="vijesti">
    <div class="vijesti-inner">
      <div class="vijesti-header">
        <div style="margin-bottom:0;">
          <div class="section-label reveal">Vijesti</div>
          <h2 class="section-title reveal">Najnovije iz konjičkog sporta</h2>
        </div>
        <a href="#" class="btn btn-blue reveal" style="flex-shrink:0;">Sve vijesti</a>
      </div>
      <div class="vijesti-grid">
        {vijesti.map((vijest, i) => (
          <a class={`vijesti-card ${i === 0 ? 'vijesti-card-featured' : ''} reveal ${i === 1 ? 'reveal-d1' : ''} ${i === 2 ? 'reveal-d2' : ''}`} href={`/vijesti/${vijest.id}`}>
            {vijest.data.image && (
              <div class="vijesti-card-img">
                <img src={vijest.data.image} alt={vijest.data.title}>
              </div>
            )}
            <div class="vijesti-card-body">
              <div class="vijesti-tag">
                {vijest.data.category && <span>{categoryLabel(vijest.data.category)}</span>}
                {vijest.data.discipline && <span>{disciplineLabel(vijest.data.discipline)}</span>}
              </div>
              <h3>{vijest.data.title}</h3>
              {vijest.data.excerpt && i === 0 && <p>{vijest.data.excerpt}</p>}
              <div class="vijesti-card-date">{formatDate(new Date(vijest.data.date))}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DISCIPLINES -->
  <section class="section discipline-section" id="discipline">
    <div class="discipline-inner">
      <div class="section-header reveal" style="text-align:center; margin-bottom:3rem;">
        <div class="section-label" style="justify-content:center;">Konjički sport</div>
        <h2 class="section-title">Discipline</h2>
        <p class="section-desc" style="margin:0 auto;">FEI prepoznate discipline u kojima muškarci i žene ravnopravno nastupaju — individualno ili timski.</p>
      </div>
      <div class="discipline-grid">
        <a class="discipline-card reveal reveal-d1" href="/konjicki-sport#preponsko">
          <div class="discipline-card-bg" style="background-image:url('/images/preponsko.jpg')"></div>
          <div class="discipline-card-overlay"></div>
          <div class="discipline-card-content">
            <div class="discipline-card-num">01</div>
            <h3>Preponsko jahanje</h3>
            <p>Najpoznatija disciplina — jahač i konj zajedno svladavaju parcours prepona u zadanom vremenu.</p>
          </div>
        </a>
        <a class="discipline-card reveal reveal-d2" href="/konjicki-sport#dresurno">
          <div class="discipline-card-bg" style="background-image:url('/images/dresurno.jpg')"></div>
          <div class="discipline-card-overlay"></div>
          <div class="discipline-card-content">
            <div class="discipline-card-num">02</div>
            <h3>Dresurno jahanje</h3>
            <p>Elegancija i preciznost — savršena harmonija jahača i konja, poznata kao "balet na konju".</p>
          </div>
        </a>
        <a class="discipline-card reveal reveal-d3" href="/konjicki-sport#daljinsko">
          <div class="discipline-card-bg" style="background-image:url('/images/daljinsko.jpg')"></div>
          <div class="discipline-card-overlay"></div>
          <div class="discipline-card-content">
            <div class="discipline-card-num">03</div>
            <h3>Daljinsko jahanje</h3>
            <p>Izdržljivost, strategija i duboka povezanost s konjem na dugim stazama kroz raznolike terene.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- EVENT -->
  <section class="section event-section" id="turnir">
    <div class="event-inner">
      <div class="event-visual reveal">
        <img src="https://images.unsplash.com/photo-1566251037378-5e04e3bec343?w=900&q=80" alt="Lipanjski turnir">
      </div>
      <div class="event-info">
        <div>
          <div class="section-label reveal">Istaknuti događaj</div>
          <h2 class="section-title reveal">70. Lipanjski turnir<br>FEI World Cup Zagreb</h2>
          <p class="section-desc reveal">Svjetska elita preponskog jahanja vraća se u Zagreb nakon 18 godina! Hipodrom ponovno postaje pozornica vrhunskog sporta.</p>
        </div>
        <div class="event-meta reveal">
          <div class="event-meta-item"><div class="event-meta-label">Datum</div><div class="event-meta-value">11.–14. lipnja 2026.</div></div>
          <div class="event-meta-item"><div class="event-meta-label">Lokacija</div><div class="event-meta-value">Hipodrom Zagreb</div></div>
          <div class="event-meta-item"><div class="event-meta-label">Kategorije</div><div class="event-meta-value">CSI2*-W · CSI1* · CSIYH1*</div></div>
          <div class="event-meta-item"><div class="event-meta-label">Tradicija</div><div class="event-meta-value">70 godina</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SCHOOLS CTA -->
  <section class="section schools" id="skole">
    <div class="schools-inner">
      <div class="reveal">
        <div>
          <div class="section-label">Škole jahanja</div>
          <h2 class="section-title">Započni svoju konjičku avanturu</h2>
          <p class="section-desc">Zagrebački konjički savez okuplja kvalitetne škole jahanja za sve uzraste — od početnika do naprednih jahača.</p>
        </div>
        <a href="/skole-jahanja" class="btn btn-blue" style="margin-top:1.5rem;">Pronađi školu</a>
      </div>
      <div class="schools-img reveal reveal-d1">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80" alt="Škola jahanja">
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="kontakt">
    <div class="contact-inner">
      <div class="reveal">
        <div class="section-label">Kontakt</div>
        <h2 class="section-title">Kontaktni podaci</h2>
        <p class="section-desc">Imate pitanja o natjecanjima, članstvu ili školi jahanja? Javite nam se.</p>
        <div class="contact-cards">
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
            <div><div class="contact-card-label">Adresa</div><div class="contact-card-value">Trg Krešimira Ćosića 11, 10 000 Zagreb</div></div>
          </div>
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></div>
            <div><div class="contact-card-label">Telefon</div><div class="contact-card-value">092 30 60 943</div></div>
          </div>
          <div class="contact-card">
            <div class="contact-icon"><svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
            <div><div class="contact-card-label">E-mail</div><div class="contact-card-value">zgkonji@gmail.com</div></div>
          </div>
        </div>
      </div>
      <div class="contact-map reveal reveal-d1">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2781.3!2d15.9745!3d45.8125!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4765d70b9b3a5555%3A0x1234567890abcdef!2sTrg%20Kre%C5%A1imira%20%C4%86osi%C4%87a%2011%2C%2010000%2C%20Zagreb!5e0!3m2!1shr!2shr!4v1700000000000!5m2!1shr!2shr" loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <div class="partners">
    <div class="partners-inner">
      <span class="partners-label">Partneri</span>
      <span style="font-size:0.9rem;color:var(--gray-400);font-weight:600;">HKS</span>
      <span style="font-size:0.9rem;color:var(--gray-400);font-weight:600;">Grad Zagreb</span>
      <span style="font-size:0.9rem;color:var(--gray-400);font-weight:600;">SSGZ</span>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Stilovi SAMO za naslovnicu ── */
  .hero { position: relative; min-height: 75vh; display: flex; align-items: center; overflow: hidden; background: var(--gray-900); }
  .hero-bg { position: absolute; inset: 0; background: linear-gradient(to right, rgba(27,58,107,0.88) 0%, rgba(27,58,107,0.55) 50%, rgba(27,58,107,0.35) 100%), url('https://images.unsplash.com/photo-1553284965-83fd3e82fa5a?w=1920&q=80') center/cover no-repeat; }
  .hero-content { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 5rem 3rem; width: 100%; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); border-radius: 3px; padding: 0.4rem 1rem; margin-bottom: 1.8rem; color: #fff; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; animation: fadeUp 0.7s ease-out 0.2s both; }
  .hero-badge-dot { width: 7px; height: 7px; background: #4ade80; border-radius: 50%; animation: blink 2s infinite; }
  @keyframes blink { 0%,100%{opacity:1}50%{opacity:0.3} }
  .hero h1 { font-family: var(--serif); font-size: clamp(2.2rem, 4.5vw, 3.4rem); color: #fff; font-weight: 700; line-height: 1.15; margin-bottom: 1.2rem; max-width: 650px; animation: fadeUp 0.7s ease-out 0.4s both; }
  .hero p { font-size: 1.1rem; color: rgba(255,255,255,0.8); line-height: 1.7; max-width: 520px; margin-bottom: 2rem; animation: fadeUp 0.7s ease-out 0.6s both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.7s ease-out 0.8s both; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(25px); } to { opacity: 1; transform: translateY(0); } }

  .stats-bar { background: var(--white); border-bottom: 1px solid var(--gray-200); padding: 0 2rem; }
  .stats-bar-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat-item { text-align: center; padding: 2rem 1rem; border-right: 1px solid var(--gray-200); }
  .stat-item:last-child { border-right: none; }
  .stat-number { font-family: var(--serif); font-size: 2.2rem; font-weight: 700; color: var(--blue); line-height: 1; margin-bottom: 0.25rem; }
  .stat-label { font-size: 0.78rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }

  .vijesti { background: var(--off-white); }
  .vijesti-inner { max-width: 1200px; margin: 0 auto; }
  .vijesti-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; }
  .vijesti-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .vijesti-card { display: flex; flex-direction: column; background: var(--white); border-radius: 6px; overflow: hidden; border: 1px solid var(--gray-200); transition: transform 0.3s, box-shadow 0.3s; text-decoration: none; color: inherit; }
  .vijesti-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
  .vijesti-card-featured { grid-column: 1 / -1; flex-direction: row; }
  .vijesti-card-img { overflow: hidden; flex-shrink: 0; }
  .vijesti-card:not(.vijesti-card-featured) .vijesti-card-img { aspect-ratio: 16/9; }
  .vijesti-card-featured .vijesti-card-img { width: 50%; min-height: 320px; }
  .vijesti-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .vijesti-card:hover .vijesti-card-img img { transform: scale(1.04); }
  .vijesti-card-body { padding: 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; }
  .vijesti-card-featured .vijesti-card-body { padding: 2rem 2.5rem; }
  .vijesti-tag { display: inline-flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
  .vijesti-tag span { font-size: 0.65rem; font-weight: 700; color: var(--blue); background: var(--blue-pale); padding: 0.2rem 0.55rem; border-radius: 2px; letter-spacing: 0.06em; text-transform: uppercase; }
  .vijesti-card h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 700; color: var(--gray-800); line-height: 1.4; margin-bottom: 0.5rem; }
  .vijesti-card-featured h3 { font-size: 1.35rem; }
  .vijesti-card p { font-size: 0.9rem; color: var(--gray-500); line-height: 1.6; margin-bottom: 0.8rem; }
  .vijesti-card-date { font-size: 0.75rem; color: var(--gray-400); font-weight: 500; margin-top: auto; }

  .discipline-section { background: var(--white); }
  .discipline-inner { max-width: 1200px; margin: 0 auto; }
  .discipline-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .discipline-card { position: relative; border-radius: 6px; overflow: hidden; aspect-ratio: 3/4; cursor: pointer; text-decoration: none; }
  .discipline-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.6s; }
  .discipline-card:hover .discipline-card-bg { transform: scale(1.06); }
  .discipline-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(27,58,107,0.92) 0%, rgba(27,58,107,0.4) 45%, rgba(27,58,107,0.15) 100%); transition: background 0.4s; }
  .discipline-card:hover .discipline-card-overlay { background: linear-gradient(to top, rgba(27,58,107,0.96) 0%, rgba(27,58,107,0.55) 50%, rgba(27,58,107,0.25) 100%); }
  .discipline-card-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 1.8rem; }
  .discipline-card-num { font-family: var(--serif); font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.6); margin-bottom: 0.4rem; }
  .discipline-card h3 { font-family: var(--serif); font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.6rem; }
  .discipline-card p { font-size: 0.88rem; color: rgba(255,255,255,0.75); line-height: 1.55; max-height: 0; overflow: hidden; opacity: 0; transition: max-height 0.4s, opacity 0.4s; }
  .discipline-card:hover p { max-height: 100px; opacity: 1; }

  .event-section { background: var(--blue-nav); position: relative; overflow: hidden; }
  .event-section::before { content: ''; position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.05), transparent 70%); border-radius: 50%; }
  .event-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: center; position: relative; z-index: 1; }
  .event-visual { border-radius: 6px; overflow: hidden; aspect-ratio: 4/3; box-shadow: 0 20px 50px rgba(0,0,0,0.25); }
  .event-visual img { width: 100%; height: 100%; object-fit: cover; }
  .event-info .section-label { color: rgba(255,255,255,0.6); }
  .event-info .section-title { color: #fff; }
  .event-info .section-desc { color: rgba(255,255,255,0.7); }
  .event-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
  .event-meta-item { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 1rem; }
  .event-meta-label { font-size: 0.65rem; color: rgba(255,255,255,0.5); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; margin-bottom: 0.3rem; }
  .event-meta-value { color: #fff; font-size: 0.95rem; font-weight: 600; }

  .schools { background: var(--off-white); }
  .schools-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .schools-img { border-radius: 6px; overflow: hidden; aspect-ratio: 4/3; }
  .schools-img img { width: 100%; height: 100%; object-fit: cover; }

  .contact-section { background: var(--white); }
  .contact-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.4fr; gap: 3rem; }
  .contact-cards { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
  .contact-card { display: flex; gap: 1rem; align-items: flex-start; background: var(--off-white); border: 1px solid var(--gray-200); border-radius: 8px; padding: 1.2rem; transition: border-color 0.3s; }
  .contact-card:hover { border-color: var(--blue-nav); }
  .contact-icon { width: 42px; height: 42px; flex-shrink: 0; background: var(--blue); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .contact-icon svg { width: 18px; height: 18px; color: #fff; }
  .contact-card-label { font-size: 0.65rem; color: var(--gray-400); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; margin-bottom: 0.15rem; }
  .contact-card-value { font-size: 0.95rem; color: var(--gray-800); font-weight: 600; }
  .contact-map { border-radius: 8px; overflow: hidden; border: 1px solid var(--gray-200); min-height: 350px; }
  .contact-map iframe { width: 100%; height: 100%; min-height: 350px; border: 0; }

  .partners { padding: 3rem 2rem; border-top: 1px solid var(--gray-200); background: var(--white); }
  .partners-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .partners-label { font-size: 0.7rem; color: var(--gray-400); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; }

  @media (max-width: 1024px) {
    .vijesti-grid { grid-template-columns: 1fr; }
    .vijesti-card-featured { flex-direction: column; }
    .vijesti-card-featured .vijesti-card-img { width: 100%; min-height: 220px; }
    .discipline-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
    .event-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .schools-inner { grid-template-columns: 1fr; }
    .contact-inner { grid-template-columns: 1fr; }
    .stats-bar-inner { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(2) { border-right: none; }
  }
  @media (max-width: 640px) {
    .hero-content { padding: 4rem 1.5rem; }
    .hero-actions { flex-direction: column; }
    .event-meta { grid-template-columns: 1fr; }
  }
</style>
