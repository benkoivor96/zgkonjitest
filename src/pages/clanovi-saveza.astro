---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('stranice', 'clanovi-saveza');
const d = entry.data as Record<string, any>;

const title = d.title || 'Članovi saveza';
const intro = d.intro || '';
const klubovi: {naziv: string; predsjednik: string; adresa: string; telefon?: string; email: string; oib?: string}[] = d.klubovi || [];

function getInitials(name: string): string {
  const words = name.replace(/Konjički klub /i, '').replace(/Sportski konjički klub /i, '').trim();
  return words.substring(0, 2).toUpperCase();
}
---
<BaseLayout title={title} activePage="/clanovi-saveza">

  <section class="page-hero">
    <div class="page-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">Članovi saveza</span>
      </div>
      <h1>Članovi saveza</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="section clanovi-section">
    <div class="clanovi-inner">
      <div class="clanovi-header reveal">
        <div class="section-label">Klubovi</div>
        <h2 class="section-title">Konjički klubovi Grada Zagreba</h2>
        <p class="clanovi-count">{klubovi.length} aktivnih klubova</p>
      </div>

      <div class="clanovi-grid">
        {klubovi.map((klub, i) => (
          <div class="klub-card reveal">
            <div class="klub-card-header">
              <div class="klub-avatar">{getInitials(klub.naziv)}</div>
              <div>
                <h3>{klub.naziv}</h3>
                <div class="klub-predsjednik">
                  <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  {klub.predsjednik}
                </div>
              </div>
            </div>
            <div class="klub-card-details">
              <div class="klub-detail">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>{klub.adresa}</span>
              </div>
              {klub.telefon && (
                <div class="klub-detail">
                  <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  <span>{klub.telefon}</span>
                </div>
              )}
              <div class="klub-detail">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href={`mailto:${klub.email}`}>{klub.email}</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .clanovi-section { background: var(--off-white); }
  .clanovi-inner { max-width: 1200px; margin: 0 auto; }
  .clanovi-header { margin-bottom: 2.5rem; }
  .clanovi-count { font-size: 0.88rem; color: var(--gray-400); font-weight: 500; margin-top: 0.3rem; }

  .clanovi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .klub-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .klub-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  }

  .klub-card-header {
    display: flex; gap: 1rem; align-items: flex-start;
    margin-bottom: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--gray-200);
  }

  .klub-avatar {
    width: 48px; height: 48px; flex-shrink: 0;
    background: var(--blue);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif);
    font-size: 0.9rem; font-weight: 700;
    color: #fff;
  }

  .klub-card-header h3 {
    font-family: var(--serif);
    font-size: 1rem; font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .klub-predsjednik {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.78rem; color: var(--gray-500); font-weight: 500;
  }
  .klub-predsjednik svg { width: 13px; height: 13px; flex-shrink: 0; }

  .klub-card-details {
    display: flex; flex-direction: column; gap: 0.5rem;
  }

  .klub-detail {
    display: flex; align-items: flex-start; gap: 0.5rem;
    font-size: 0.82rem; color: var(--gray-600);
  }
  .klub-detail svg {
    width: 14px; height: 14px; flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--blue);
  }
  .klub-detail a {
    color: var(--blue); text-decoration: none;
  }
  .klub-detail a:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .clanovi-grid { grid-template-columns: 1fr; max-width: 550px; margin: 0 auto; }
  }
</style>
