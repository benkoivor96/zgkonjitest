---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('stranice', 'clanovi-saveza');
const d = entry.data as Record<string, any>;

const title = d.title || 'Članovi saveza';
const intro = d.intro || '';
const klubovi: {naziv: string; predsjednik: string; adresa: string; telefon?: string; email: string; oib?: string; ziro_racun?: string}[] = d.klubovi || [];
---
<BaseLayout title={title} activePage="/clanovi-saveza">

  <section class="page-hero">
    <div class="page-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">Članovi saveza</span>
      </div>
      <h1>Članovi saveza</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="section clanovi-section">
    <div class="clanovi-inner">
      <div class="clanovi-header reveal">
        <div class="section-label">Klubovi</div>
        <h2 class="section-title">Konjički klubovi Grada Zagreba</h2>
        <p class="clanovi-count">{klubovi.length} aktivnih klubova</p>
      </div>

      <div class="clanovi-grid">
        {klubovi.map((klub) => (
          <div class="klub-card reveal">
            <h3 class="klub-name">{klub.naziv}</h3>
            <div class="klub-details">
              <div class="klub-row">
                <span class="klub-label">Naziv:</span>
                <span class="klub-value">{klub.naziv}</span>
              </div>
              <div class="klub-row">
                <span class="klub-label">Predsjednik:</span>
                <span class="klub-value">{klub.predsjednik}</span>
              </div>
              <div class="klub-row">
                <span class="klub-label">Adresa:</span>
                <span class="klub-value">{klub.adresa}</span>
              </div>
              {klub.telefon && (
                <div class="klub-row">
                  <span class="klub-label">Tel:</span>
                  <span class="klub-value">{klub.telefon}</span>
                </div>
              )}
              <div class="klub-row">
                <span class="klub-label">Email:</span>
                <span class="klub-value"><a href={`mailto:${klub.email}`}>{klub.email}</a></span>
              </div>
              {klub.oib && (
                <div class="klub-row">
                  <span class="klub-label">OIB:</span>
                  <span class="klub-value">{klub.oib}</span>
                </div>
              )}
              {klub.ziro_racun && (
                <div class="klub-row">
                  <span class="klub-label">Žiro-račun:</span>
                  <span class="klub-value">{klub.ziro_racun}</span>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .clanovi-section { background: var(--off-white); }
  .clanovi-inner { max-width: 1200px; margin: 0 auto; }
  .clanovi-header { margin-bottom: 2.5rem; }
  .clanovi-count { font-size: 0.88rem; color: var(--gray-400); font-weight: 500; margin-top: 0.3rem; }

  .clanovi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .klub-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .klub-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  }

  .klub-name {
    font-family: var(--serif);
    font-size: 1.1rem; font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid var(--blue-pale);
  }

  .klub-details {
    display: flex; flex-direction: column; gap: 0.4rem;
  }

  .klub-row {
    display: flex; gap: 0.5rem;
    font-size: 0.88rem; line-height: 1.5;
  }

  .klub-label {
    font-weight: 700; color: var(--gray-700);
    flex-shrink: 0; min-width: 95px;
  }

  .klub-value {
    color: var(--gray-600);
  }

  .klub-value a {
    color: var(--blue); text-decoration: none;
  }
  .klub-value a:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .clanovi-grid { grid-template-columns: 1fr; max-width: 550px; margin: 0 auto; }
  }
  @media (max-width: 640px) {
    .klub-row { flex-direction: column; gap: 0.1rem; }
    .klub-label { min-width: auto; }
  }
</style>
