---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('stranice', 'lipanjski-turnir');
const { Content } = await render(entry);
const d = entry.data as Record<string, any>;

const title = d.title || 'Lipanjski turnir';
const datum = d.datum || '';
const lokacija = d.lokacija || 'Hipodrom Zagreb';
const kategorije = d.kategorije || '';
const slika = d.slika || '';
const ulaz = d.ulaz || '';
const nagradniFond = d.nagradni_fond || '';
const peharVisina = d.pehar_visina || '';
const highlight = d.highlight || '';

const infoItems = [
  { label: 'Datum', value: datum, icon: 'calendar' },
  { label: 'Lokacija', value: lokacija, icon: 'location' },
  { label: 'Kategorije', value: kategorije, icon: 'trophy' },
  { label: 'Ulaz', value: ulaz, icon: 'ticket' },
].filter(item => item.value);
---
<BaseLayout title={title} activePage="/lipanjski-turnir">

  <!-- HERO -->
  <section class="turnir-hero">
    <div class="turnir-hero-bg"></div>
    <div class="turnir-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">Lipanjski turnir</span>
      </div>
      <div class="turnir-badge">FEI World Cup · Preponsko jahanje</div>
      <h1>{title}</h1>
      {highlight && <p class="turnir-highlight">{highlight}</p>}
    </div>
  </section>

  <!-- INFO BAR -->
  <section class="turnir-info-bar">
    <div class="turnir-info-inner">
      {infoItems.map((item) => (
        <div class="turnir-info-item">
          <div class="turnir-info-icon">
            {item.icon === 'calendar' && <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>}
            {item.icon === 'location' && <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
            {item.icon === 'trophy' && <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>}
            {item.icon === 'ticket' && <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>}
          </div>
          <div>
            <div class="turnir-info-label">{item.label}</div>
            <div class="turnir-info-value">{item.value}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CONTENT -->
  <section class="section turnir-content-section">
    <div class="turnir-content-inner">
      <div class="turnir-main reveal">
        {slika && (
          <div class="turnir-image">
            <img src={slika} alt={title} />
          </div>
        )}
        <div class="turnir-text">
          <Content />
        </div>
      </div>

      <div class="turnir-sidebar reveal">
        <div class="sidebar-card">
          <h3>Informacije o turniru</h3>
          <div class="sidebar-items">
            {datum && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Datum</div>
                <div class="sidebar-item-value">{datum}</div>
              </div>
            )}
            {lokacija && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Lokacija</div>
                <div class="sidebar-item-value">{lokacija}</div>
              </div>
            )}
            {kategorije && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Kategorije</div>
                <div class="sidebar-item-value">{kategorije}</div>
              </div>
            )}
            {peharVisina && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Pehar Grada Zagreba</div>
                <div class="sidebar-item-value">Visina prepona: {peharVisina}</div>
              </div>
            )}
            {nagradniFond && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Nagradni fond</div>
                <div class="sidebar-item-value">{nagradniFond}</div>
              </div>
            )}
            {ulaz && (
              <div class="sidebar-item">
                <div class="sidebar-item-label">Ulaz</div>
                <div class="sidebar-item-value">{ulaz}</div>
              </div>
            )}
          </div>
        </div>

        <div class="sidebar-card sidebar-cta">
          <h3>Organizator</h3>
          <p>Zagrebački konjički savez</p>
          <a href="/o-nama#kontakt" class="btn btn-blue">Kontaktirajte nas</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .turnir-hero {
    position: relative; padding: 6rem 2rem 5rem;
    background: var(--blue-deeper); overflow: hidden;
  }
  .turnir-hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, rgba(27,58,107,0.94) 0%, rgba(15,34,64,0.85) 100%),
      url('https://images.unsplash.com/photo-1553284965-83fd3e82fa5a?w=1600&q=80') center/cover;
  }
  .turnir-hero-content {
    position: relative; z-index: 1;
    max-width: 800px; margin: 0 auto; text-align: center;
  }
  .turnir-badge {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 3px; padding: 0.4rem 1rem;
    margin-bottom: 1.5rem;
    color: #fff; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .turnir-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: #fff; font-weight: 700;
    line-height: 1.15; margin-bottom: 1.2rem;
  }
  .turnir-highlight {
    font-size: 1.1rem; color: rgba(255,255,255,0.75);
    line-height: 1.7; max-width: 650px; margin: 0 auto;
  }

  .turnir-info-bar {
    background: var(--blue);
    padding: 0 2rem;
  }
  .turnir-info-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr);
  }
  .turnir-info-item {
    display: flex; gap: 0.8rem; align-items: center;
    padding: 1.5rem 1rem;
    border-right: 1px solid rgba(255,255,255,0.1);
  }
  .turnir-info-item:last-child { border-right: none; }
  .turnir-info-icon {
    width: 40px; height: 40px; flex-shrink: 0;
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .turnir-info-icon svg { width: 18px; height: 18px; color: #fff; }
  .turnir-info-label {
    font-size: 0.62rem; color: rgba(255,255,255,0.5);
    letter-spacing: 0.12em; text-transform: uppercase;
    font-weight: 700; margin-bottom: 0.1rem;
  }
  .turnir-info-value { font-size: 0.88rem; color: #fff; font-weight: 600; }

  .turnir-content-section { background: var(--off-white); }
  .turnir-content-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 360px;
    gap: 3rem; align-items: flex-start;
  }

  .turnir-image {
    border-radius: 8px; overflow: hidden;
    margin-bottom: 2rem;
  }
  .turnir-image img { width: 100%; height: auto; display: block; }

  .turnir-text { font-size: 1rem; color: var(--gray-700); line-height: 1.85; }
  .turnir-text p { margin-bottom: 1.2rem; }
  .turnir-text h2 { font-family: var(--serif); font-size: 1.4rem; font-weight: 700; color: var(--gray-800); margin: 2rem 0 0.8rem; }
  .turnir-text strong { color: var(--gray-800); }
  .turnir-text blockquote {
    background: var(--blue-pale); border-left: 3px solid var(--blue);
    padding: 1rem 1.2rem; border-radius: 0 6px 6px 0; margin: 1.2rem 0;
  }
  .turnir-text blockquote p { font-size: 0.92rem; color: var(--blue-dark); font-weight: 500; margin-bottom: 0; }

  .sidebar-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .sidebar-card h3 {
    font-family: var(--serif);
    font-size: 1rem; font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--gray-200);
  }
  .sidebar-items { display: flex; flex-direction: column; gap: 0.8rem; }
  .sidebar-item {}
  .sidebar-item-label {
    font-size: 0.65rem; color: var(--gray-400);
    letter-spacing: 0.12em; text-transform: uppercase;
    font-weight: 700; margin-bottom: 0.1rem;
  }
  .sidebar-item-value { font-size: 0.9rem; color: var(--gray-800); font-weight: 600; }

  .sidebar-cta { text-align: center; }
  .sidebar-cta p {
    font-size: 0.9rem; color: var(--gray-500);
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .turnir-info-inner { grid-template-columns: repeat(2, 1fr); }
    .turnir-info-item:nth-child(2) { border-right: none; }
    .turnir-content-inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .turnir-hero { padding: 4rem 1.5rem 3rem; }
    .turnir-info-inner { grid-template-columns: 1fr; }
    .turnir-info-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .turnir-info-item:last-child { border-bottom: none; }
  }
</style>
