---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const sviDokumenti = await getCollection('dokumenti');

const categoryLabels: Record<string, string> = {
  statut: 'Statut',
  pravilnici: 'Pravilnici',
  tablice: 'Tablice bodovanja',
  obrasci: 'Obrasci',
  ostalo: 'Ostalo',
};

const categories = ['statut', 'pravilnici', 'tablice', 'obrasci', 'ostalo'] as const;

// Group documents by category, only include categories that have documents
const byCategory = categories
  .map(cat => ({
    key: cat,
    label: categoryLabels[cat],
    docs: sviDokumenti
      .filter(d => d.data.category === cat)
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
  }))
  .filter(g => g.docs.length > 0);
---
<BaseLayout title="Dokumenti" activePage="/dokumenti">

  <section class="page-hero">
    <div class="page-hero-content">
      <div class="page-hero-breadcrumb">
        <a href="/">Naslovnica</a>
        <span class="sep">›</span>
        <span style="color:rgba(255,255,255,0.8);">Dokumenti</span>
      </div>
      <h1>Dokumenti</h1>
    </div>
  </section>

  <section class="dok-section">
    <div class="dok-inner">

      {byCategory.length === 0 ? (
        <div class="dok-empty">
          <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p>Dokumenti još nisu objavljeni.</p>
        </div>
      ) : (
        byCategory.map(group => (
          <div class="dok-group">
            <h2 class="dok-group-title">{group.label}</h2>
            <ul class="dok-list">
              {group.docs.map(doc => (
                <li class="dok-item">
                  <div class="dok-icon">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                      <path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div class="dok-info">
                    <span class="dok-title">{doc.data.title}</span>
                    <span class="dok-date">{new Date(doc.data.date).getFullYear()}.</span>
                  </div>
                  {doc.data.file && (
                    <a href={doc.data.file} target="_blank" rel="noopener" class="dok-download">
                      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/>
                      </svg>
                      Preuzmi
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      )}

    </div>
  </section>

</BaseLayout>

<style>
  .dok-section { padding: 3rem 2rem 5rem; background: var(--white); }
  .dok-inner { max-width: 760px; margin: 0 auto; }

  .dok-empty { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 5rem 2rem; color: var(--gray-400); text-align: center; }
  .dok-empty p { font-size: 0.95rem; }

  .dok-group { margin-bottom: 3rem; }
  .dok-group-title { font-family: var(--serif); font-size: 1.1rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.75rem; padding-bottom: 0.6rem; border-bottom: 2px solid var(--blue-pale); }

  .dok-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .dok-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--gray-100);
    transition: background 0.15s;
  }
  .dok-item:hover { background: var(--blue-pale); }
  .dok-icon { color: var(--blue); flex-shrink: 0; }
  .dok-info { display: flex; align-items: baseline; gap: 0.75rem; flex: 1; min-width: 0; }
  .dok-title { font-size: 0.95rem; font-weight: 600; color: var(--gray-800); }
  .dok-date { font-size: 0.8rem; color: var(--gray-400); white-space: nowrap; }
  .dok-download {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.82rem; font-weight: 600; color: var(--blue);
    text-decoration: none; white-space: nowrap;
    padding: 0.35rem 0.85rem; border: 1.5px solid var(--blue);
    border-radius: 4px; transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .dok-download:hover { background: var(--blue); color: white; }

  @media (max-width: 500px) {
    .dok-item { flex-wrap: wrap; }
    .dok-info { width: 100%; }
  }
</style>
