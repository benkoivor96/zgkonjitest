---
/* Header.astro — logo + naziv saveza
   Promijeni logo ili naziv OVDJE → svugdje ažurirano */
---
<header class="site-header">
  <img src="/images/logo.png" alt="Zagrebački konjički savez — grb" class="header-logo">
  <h1 class="header-title">Zagrebački konjički savez</h1>
  <p class="header-subtitle">Zagreb Equestrian Association</p>
</header>

<style>
  .site-header { background: var(--white); text-align: center; padding: 2rem 2rem 1.5rem; border-bottom: 1px solid var(--gray-200); }
  .header-logo { width: 90px; height: auto; margin-bottom: 0.8rem; }
  .header-title { font-family: var(--serif); font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: var(--blue); font-weight: 700; line-height: 1.2; margin-bottom: 0.3rem; }
  .header-subtitle { font-size: 0.82rem; color: var(--gray-500); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; }
  @media (max-width: 640px) { .site-header { padding: 1.5rem 1rem 1rem; } }
</style>
